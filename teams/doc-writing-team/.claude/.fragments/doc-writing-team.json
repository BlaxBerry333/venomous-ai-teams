{
  "permissions": {
    "deny": [
      "Bash(sudo *)",
      "Bash(shutdown*)",
      "Bash(git push --force:*)",
      "Bash(curl * | sh)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {"type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/doc-writing-team/path-guard.sh"}
        ]
      }
    ]
  }
}
